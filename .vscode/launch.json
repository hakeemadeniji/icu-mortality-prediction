{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Backend Server",
      "type": "debugpy",
      "request": "launch",
      "module": "backend.main",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/backend/.env"
    },
    {
      "name": "Python: Run Backend Script",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/main.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/backend/.env"
    }
  ]
}