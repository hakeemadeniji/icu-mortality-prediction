# ICU Mortality Prediction System - Backend Configuration (template)
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# API Settings
HOST=0.0.0.0
PORT=8054
DEBUG=True

# Anthropic API (Claude) - get a key at https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL_DEFAULT=claude-opus-4-8
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# GLM API (Zhipu) - get a key at https://open.bigmodel.cn
ENABLE_GLM=true
GLM_API_KEY=your-glm-key-here
GLM_MODEL=glm-4-plus

# Database Settings
DATABASE_URL=sqlite:///./icu_mortality.db
VECTOR_DB_PATH=./rag_system/vector_db/chroma

# Model Settings
MODEL_PATH=./onnx_models
ONNX_OPTIMIZED=true
ARM64_OPTIMIZED=true
USE_NPU=true
BATCH_SIZE=32
MAX_SEQUENCE_LENGTH=48

# Agent Settings
NUM_AGENTS=21
AGENT_TIMEOUT=300
ENABLE_RAG=true
AGENT_PARALLEL_EXECUTION=true
MAX_CONCURRENT_AGENTS=5

# RAG Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# Data Sources
ENABLE_MIMIC=false
ENABLE_EICU=false
ENABLE_SICDB=true
ENABLE_NWICU=true
ENABLE_HIRID=true
ENABLE_PHYSIONET_CHALLENGE=true
ENABLE_WHO_MORTALITY=true
ENABLE_CDC_DATA=true

# Evaluation Settings
ENABLE_CONTINUOUS_EVAL=true
EVAL_INTERVAL_HOURS=24
DRIFT_THRESHOLD=0.1

# Monitoring Settings
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090
ENABLE_GRAFANA=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Frontend Configuration
FRONTEND_URL=http://localhost:3054
ENABLE_CORS=true
